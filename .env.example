# ============================================================
# APIAuto 环境变量示例文件
# 用法：复制为 .env 后按需修改；.env 已在 .gitignore 中忽略
# 所有变量均可覆盖 config/config.yaml 中同名字段
# ============================================================

# 被测服务基础地址（覆盖 config.yaml base.url）
API_BASE_URL=http://127.0.0.1:5000

# 默认登录账号（覆盖 config.yaml user.*；仅用于 mock 环境）
API_USERNAME=testuser
API_PASSWORD=Test@123

# 数据库路径（相对项目根；仅用于本地 mock）
API_DB_PATH=test.db

# 运行环境标识：dev / test / staging / prod
API_ENV=dev

# 请求默认超时（秒）
API_REQUEST_TIMEOUT=30

# 请求失败重试次数
API_REQUEST_RETRIES=0

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
